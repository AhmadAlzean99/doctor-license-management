# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Force LF for cross-platform code
*.cs        text eol=lf
*.csproj    text eol=lf
*.sln       text eol=crlf
*.json      text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.md        text eol=lf
*.sql       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Force CRLF for Windows-only files
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binaries — never modify
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
